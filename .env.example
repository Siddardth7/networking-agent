# Networking Agent — Environment Variables
# Copy to .env or export in your shell. Never commit real values.

# Required: LLM provider
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Primary LinkedIn discovery (Apify — harvestapi/linkedin-profile-search)
APIFY_API_KEY=apify_REPLACE_ME

# Search provider (Serper.dev) — now the FALLBACK behind Apify
SERPER_API_KEY=REPLACE_ME

# Required: Email finder (Hunter.io) — primary email source
HUNTER_API_KEY=REPLACE_ME

# Optional: Apollo.io — email FALLBACK after Hunter (only used when email
# enrichment is enabled)
APOLLO_API_KEY=REPLACE_ME

# NOTE: these are read from the environment OR from ~/.networking-agent/config.yaml
# under `keys:`. This .env file is NOT auto-loaded — either export the vars in
# your shell, or put the real values in config.yaml (where the loader reads them).

# Optional: override default config path
# NETWORKING_AGENT_CONFIG=~/.networking-agent/config.yaml
